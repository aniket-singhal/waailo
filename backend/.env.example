# ---- Application ----
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://waailo:waailo@localhost:5432/waailo?schema=public

# ---- Auth / JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=2592000
INVITE_TOKEN_TTL=604800
RESET_TOKEN_TTL=3600

# ---- Redis (queues/cache — used from Phase 2) ----
REDIS_URL=redis://localhost:6379

# ---- Object storage (documents) ----
# STORAGE_DRIVER: "local" for dev, "s3" for staging/prod
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.storage
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=waailo-documents
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
